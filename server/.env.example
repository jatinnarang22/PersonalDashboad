PORT=3000

# true = no Docker / mongod required (uses mongodb-memory-server; data resets on restart)
USE_MEMORY_MONGO=true

# Used when USE_MEMORY_MONGO=false — e.g. mongodb://127.0.0.1:27017/personal_dashboard
MONGODB_URI=mongodb://127.0.0.1:27017/personal_dashboard

# Session cookie signing (use a long random string in production)
SESSION_SECRET=change-me-in-production

# Vue dev server origin (CORS + credentials)
CLIENT_ORIGIN=http://localhost:5173

# --- YouTube (Google OAuth) — optional; Data API does not expose private watch history ---
# Create OAuth client (Web) in Google Cloud Console; add redirect URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/youtube/callback

# --- Instagram (Meta / Facebook Login) — requires Instagram Professional + Facebook Page ---
# Create a Meta app with Instagram Graph API + Facebook Login; use redirect URI below.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/integrations/instagram/callback

# Instagram without META_*: use dashboard "Page access token + Instagram User ID" or "User token"
# (tokens are stored in MongoDB on your user — never commit tokens to git).
